---
import { withBase } from "@lib/paths";

type Props = {
  src: string;
  alt: string;
  caption?: string;
};

const { src, alt, caption } = Astro.props;
---

<figure class="research-figure">
  <img src={withBase(src)} alt={alt} loading="lazy" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>
