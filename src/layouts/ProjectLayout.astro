---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { withBase } from "@lib/paths";
import type { Locale } from "@lib/paths";

type Props = {
  project: CollectionEntry<"projects">;
  locale?: Locale;
};

const { project, locale = "zh" } = Astro.props as Props;
const cover = withBase(project.data.cover);
---

<BaseLayout title={project.data.title} description={project.data.summary} locale={locale}>
  <article class="project-detail">
    <header class="project-header">
      <p class="section-kicker">
        {project.data.date.getFullYear()} · {project.data.tags.join(" / ")}
      </p>
      <h2>{project.data.title}</h2>
      <p class="summary">{project.data.summary}</p>
      {project.data.links.length > 0 && (
        <div class="project-links">
          {project.data.links.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer">
              {link.label}
            </a>
          ))}
        </div>
      )}
    </header>

    <img class="cover" src={cover} alt="" />

    {project.data.video && (
      <video class="project-video-player" src={project.data.video} controls preload="metadata"></video>
    )}

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .project-detail {
    display: grid;
    gap: 1.5rem;
  }

  .project-header h2 {
    font-family: var(--font-serif);
    font-size: var(--title-size);
    line-height: 1.08;
    margin: 0.1rem 0 0.5rem;
  }

  .summary {
    color: var(--muted);
    max-width: 60ch;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .project-links a {
    background: var(--surface-strong);
    border-radius: 999px;
    color: var(--ink);
    padding: 0.5rem 0.85rem;
    text-decoration: none;
  }

  .cover {
    border-radius: 1.25rem;
    max-width: 100%;
  }

  .project-video-player {
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    box-shadow: var(--shadow);
    width: 100%;
  }
</style>
